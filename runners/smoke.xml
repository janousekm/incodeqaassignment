<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Suite" parallel="classes" thread-count="3">

    <test name="Smoke - Chromium">
        <parameter name="browser" value="chromium"/>
        <parameter name="headless" value="true"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.VerifyNameWithOCRNameTest"/>
            <class name="tests.AddFaceToDatabaseTest"/>
            <class name="tests.AddNewFlowTest"/>
        </classes>
    </test>

</suite>

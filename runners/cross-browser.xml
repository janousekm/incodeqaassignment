<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cross-Browser Suite" parallel="tests" thread-count="3">

    <test name="Chromium">
        <parameter name="browser" value="chromium"/>
        <parameter name="headless" value="true"/>
        <classes>
            <class name="tests.VerifyNameWithOCRNameTest"/>
            <class name="tests.AddFaceToDatabaseTest"/>
            <class name="tests.AddNewFlowTest"/>
        </classes>
    </test>

    <test name="Firefox">
        <parameter name="browser" value="firefox"/>
        <parameter name="headless" value="true"/>
        <classes>
            <class name="tests.VerifyNameWithOCRNameTest"/>
            <class name="tests.AddFaceToDatabaseTest"/>
            <class name="tests.AddNewFlowTest"/>
        </classes>
    </test>

    <test name="Webkit">
        <parameter name="browser" value="webkit"/>
        <parameter name="headless" value="true"/>
        <classes>
            <class name="tests.VerifyNameWithOCRNameTest"/>
            <class name="tests.AddFaceToDatabaseTest"/>
            <class name="tests.AddNewFlowTest"/>
        </classes>
    </test>

</suite>
